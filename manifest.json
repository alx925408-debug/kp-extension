{
  "manifest_version": 3,
  "name": "КП Генератор — ARBQ.RU",
  "version": "1.0.0",
  "key": "",
  "description": "Автоматическая генерация коммерческих предложений в PDF и DOCX по ссылке на товар. Использует локальную AI-модель (Ollama) для создания маркетингового текста.",

  "icons": {
    "16":  "icons/icon16.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "debugger",
    "downloads",
    "tabs",
    "nativeMessaging",
    "sidePanel"
  ],
  "host_permissions": ["<all_urls>"],

  "action": {
    "default_title": "КП Генератор",
    "default_icon": {
      "16":  "icons/icon16.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "side_panel": {
    "default_path": "sidepanel.html"
  },

  "options_page": "options.html",

  "background": {
    "service_worker": "background.js"
  },

  "web_accessible_resources": [{
    "resources": [
      "generate.html",
      "generate-pricelist.html",
      "icons/logo_arbq_icon.png"
    ],
    "matches": ["<all_urls>"]
  }],

  "minimum_chrome_version": "116"
}
